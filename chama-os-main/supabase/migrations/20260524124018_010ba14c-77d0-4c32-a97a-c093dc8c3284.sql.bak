
-- 1) feed_comments: require membership on UPDATE
DROP POLICY IF EXISTS "comments update by author" ON public.feed_comments;
CREATE POLICY "comments update by author member"
ON public.feed_comments
FOR UPDATE
USING (
  auth.uid() = author_id
  AND EXISTS (
    SELECT 1 FROM public.feed_posts p
    WHERE p.id = feed_comments.post_id
      AND public.is_member_of(p.chama_id, auth.uid())
  )
)
WITH CHECK (
  auth.uid() = author_id
  AND EXISTS (
    SELECT 1 FROM public.feed_posts p
    WHERE p.id = feed_comments.post_id
      AND public.is_member_of(p.chama_id, auth.uid())
  )
);

-- 2) transparency_logs: remove client-side INSERT; only service-role/SECURITY DEFINER code can write.
DROP POLICY IF EXISTS "logs insert by privileged" ON public.transparency_logs;
