-- 1) Restrict chamas.invite_code to chairperson only via column grants + RPC
REVOKE SELECT ON public.chamas FROM anon, authenticated;
GRANT SELECT (id, name, type, location, created_by, created_at, updated_at, rules)
  ON public.chamas TO anon, authenticated;

CREATE OR REPLACE FUNCTION public.get_chama_invite_code(_chama uuid)
RETURNS text
LANGUAGE sql
STABLE
SECURITY DEFINER
SET search_path = public
AS $$
  SELECT invite_code
  FROM public.chamas
  WHERE id = _chama
    AND public.has_chama_role(_chama, auth.uid(), 'chairperson'::app_role);
$$;

REVOKE ALL ON FUNCTION public.get_chama_invite_code(uuid) FROM PUBLIC;
GRANT EXECUTE ON FUNCTION public.get_chama_invite_code(uuid) TO authenticated;

-- 2) feed_posts UPDATE must also verify current chama membership
DROP POLICY IF EXISTS "feed update by author" ON public.feed_posts;
CREATE POLICY "feed update by author"
ON public.feed_posts
FOR UPDATE
USING (auth.uid() = author_id AND public.is_member_of(chama_id, auth.uid()));

-- 3) loan_guarantors INSERT must verify the guarantor is a chama member
DROP POLICY IF EXISTS "guarantor insert by borrower" ON public.loan_guarantors;
CREATE POLICY "guarantor insert by borrower"
ON public.loan_guarantors
FOR INSERT
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.loans l
    WHERE l.id = loan_guarantors.loan_id
      AND l.borrower_id = auth.uid()
      AND public.is_member_of(l.chama_id, loan_guarantors.guarantor_id)
  )
);